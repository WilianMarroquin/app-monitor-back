    "serviceRawFile": "service: laravel-api-monitor\n\nprovider:\n  name: aws\n  region: us-east-1\n  runtime: provided.al2023\n  stage: production\n  memorySize: 1024\n  environment:\n    APP_URL: https://api.monitor.mrqn-labs.com\n    APP_ENV: local\n    APP_DEBUG: true\n    APP_KEY: ${ssm:/app-budget/APP_KEY}\n\n    # Base de datos\n    DB_CONNECTION: mysql\n    DB_HOST: ${ssm:/monitor/DB_HOST}\n    DB_PORT: 4000\n    DB_DATABASE: ${ssm:/monitor/DB_DATABASE}\n    DB_USERNAME: ${ssm:/monitor/DB_USERNAME}\n    DB_PASSWORD: ${ssm:/monitor/DB_PASSWORD}\n\n    # Queue\n    QUEUE_CONNECTION: sqs\n    SQS_QUEUE: ${construct:jobs.queueUrl}\n    SQS_PREFIX: ''\n\n    SESSION_DRIVER: cookie\n    CACHE_DRIVER: array\n    SESSION_DOMAIN: .monitor.mrqn-labs.com\n    FRONTEND_URL: https://monitor.mrqn-labs.com\n    SANCTUM_STATEFUL_DOMAINS: monitor.mrqn-labs.com,api.monitor.mrqn-labs.com\n    MYSQL_ATTR_SSL_CA: /etc/pki/tls/certs/ca-bundle.crt\n    GEMINI_API_KEY: ${ssm:/app-budget/API_KEY_GEMINI}\n\nplugins:\n  - ./vendor/bref/bref\n  - serverless-domain-manager\n  - serverless-lift\n  - ./vendor/bref/extra-php-extensions # 🚀 1. Agrega esta línea\ncustom:\n  customDomain:\n    domainName: api.monitor.mrqn-labs.com\n    basePath: ''\n    stage: ${self:provider.stage}\n    createRoute53Record: true\n    apiType: http                   # Esto indica API Gateway v2 (HTTP API)\n    certificateName: monitor.mrqn-labs.com\n    endpointType: regional\n\nfunctions:\n  api:\n    handler: public/index.php\n    runtime: php-82-fpm\n    description: 'Laravel API Monitor'\n    timeout: 28\n    events:\n      - httpApi: '*'\n    layers:\n      - ${bref-extra:gd-php-82}\nconstructs:\n  # Aquí nace el Worker\n  jobs:\n    type: queue\n    worker:\n      # Usa el handler oficial de Bref para Laravel\n      # ¡No necesitas crear un archivo worker.php manual!\n      handler: Bref\\LaravelBridge\\Queue\\QueueHandler\n      runtime: php-82\n      timeout: 60 # Dale 60s para que Gemini piense tranquilo\npackage:\n  exclude:\n    - node_modules/**\n    - public/storage\n    - resources/assets/**\n    - storage/**\n    - tests/**\n    - .env\n",
    "command": [
      "deploy"
    ],
